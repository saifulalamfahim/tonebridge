{
  "manifest_version": 3,
  "name": "ToneBridge",
  "version": "0.3.0",
  "description": "Convert Bangla and Banglish into natural English without changing your meaning or tone.",
  "permissions": ["storage"],
  "host_permissions": ["https://api.groq.com/*"],
  "action": { "default_popup": "popup.html", "default_title": "ToneBridge" },
  "background": { "service_worker": "assets/background.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
